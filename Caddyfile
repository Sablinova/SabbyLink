# =============================================================================
# SabbyLink Caddy Configuration
# =============================================================================
# Automatic HTTPS with Let's Encrypt
# Reverse proxy for backend API and frontend SPA
# WebSocket support for real-time updates

# Global options
{
	# Email for Let's Encrypt notifications
	email {$ACME_EMAIL}
	
	# Use Let's Encrypt production server
	acme_ca https://acme-v02.api.letsencrypt.org/directory
	
	# Enable HTTP/3
	servers {
		protocol {
			experimental_http3
		}
	}
}

# Main domain configuration
{$DOMAIN} {
	# Security headers
	header {
		# Prevent clickjacking
		X-Frame-Options "SAMEORIGIN"
		
		# Prevent MIME type sniffing
		X-Content-Type-Options "nosniff"
		
		# XSS protection
		X-XSS-Protection "1; mode=block"
		
		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"
		
		# Remove server header for security
		-Server
		
		# Content Security Policy (adjust as needed)
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ws: wss:;"
	}
	
	# Enable gzip compression
	encode gzip zstd
	
	# API routes (proxy to backend)
	handle /api/* {
		reverse_proxy backend:3000 {
			# Health check
			health_uri /api/v1/health
			health_interval 30s
			health_timeout 10s
			
			# Headers
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	
	# WebSocket endpoint (proxy to backend)
	handle /ws {
		reverse_proxy backend:3000 {
			# WebSocket-specific headers
			header_up Connection "Upgrade"
			header_up Upgrade "websocket"
			
			# Timeouts for long-lived connections
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}
	
	# Frontend SPA (proxy to frontend container)
	handle {
		reverse_proxy frontend:80 {
			# SPA fallback - serve index.html for all non-existent files
			@notfound status 404
			handle_response @notfound {
				reverse_proxy frontend:80 {
					rewrite * /index.html
				}
			}
		}
	}
	
	# Logging
	log {
		output file /var/log/caddy/access.log {
			roll_size 100mb
			roll_keep 5
			roll_keep_for 720h
		}
		format json
		level INFO
	}
}

# Optional: www redirect (uncomment if you want www.domain.com to redirect to domain.com)
