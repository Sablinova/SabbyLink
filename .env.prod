# SabbyLink Production Environment
# Copy this to .env and fill in your values

# ===========================================
# REQUIRED - Must be set before starting
# ===========================================

# Your Discord user token (NOT a bot token)
# Get from: Browser DevTools > Network > Filter "api" > Copy Authorization header
DISCORD_TOKEN=

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# JWT secret for authentication (generate with: openssl rand -hex 32)
JWT_SECRET=

# ===========================================
# OPTIONAL - AI Providers (at least one recommended)
# ===========================================

# OpenAI (most capable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini (has free tier)
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-pro

# Groq (free, fast)
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# Default provider to use
DEFAULT_AI_PROVIDER=openai

# ===========================================
# OPTIONAL - Feature toggles
# ===========================================

ENABLE_RPC=true
ENABLE_AI_RESPONDER=false
ENABLE_NITRO_SNIPER=false
ENABLE_GIVEAWAY_JOINER=false
ENABLE_MESSAGE_LOGGER=true
ENABLE_AFK_SYSTEM=true

# ===========================================
# CORS (set to your frontend domain)
# ===========================================
CORS_ORIGIN=https://sabbylink.2b.sablinova.com
