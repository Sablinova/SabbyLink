# =============================================================================
# SabbyLink Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Discord Configuration
# -----------------------------------------------------------------------------
# Your Discord user token (WARNING: This violates Discord ToS)
# Get it from: Browser DevTools > Application > Local Storage > token
DISCORD_TOKEN=your_discord_token_here

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
# Port for the backend API server
BACKEND_PORT=3000

# Node environment (development, production, test)
NODE_ENV=production

# Database file location (SQLite)
DATABASE_URL=./data/sabbylink.db

# Secret key for encrypting sensitive data (generate a random 32-char string)
ENCRYPTION_KEY=your_random_32_character_secret_key_here

# JWT secret for authentication tokens (generate a random string)
JWT_SECRET=your_jwt_secret_key_here

# JWT expiration time (e.g., "7d" = 7 days, "24h" = 24 hours)
JWT_EXPIRES_IN=7d

# Enable debug logging (true/false)
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# Port for the frontend dev server (only used in development)
FRONTEND_PORT=5173

# Backend API URL (used by frontend to connect to backend)
# In production with Docker, use: http://backend:3000
# In development, use: http://localhost:3000
VITE_API_URL=http://localhost:3000

# WebSocket URL (used by frontend for real-time updates)
# In production with Docker, use: ws://backend:3000
# In development, use: ws://localhost:3000
VITE_WS_URL=ws://localhost:3000

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# OpenAI API key (for GPT models)
OPENAI_API_KEY=

# OpenAI model to use (gpt-4-turbo-preview, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# Anthropic model to use (claude-3-opus-20240229, claude-3-sonnet-20240229, etc.)
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google AI API key (for Gemini models)
GOOGLE_AI_API_KEY=

# Google AI model to use (gemini-pro, gemini-pro-vision, etc.)
GOOGLE_AI_MODEL=gemini-pro

# Groq API key (fast inference)
GROQ_API_KEY=

# Groq model to use (mixtral-8x7b-32768, llama2-70b-4096, etc.)
GROQ_MODEL=mixtral-8x7b-32768

# Ollama base URL (for local AI models)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use (llama2, mistral, codellama, etc.)
OLLAMA_MODEL=llama2

# OpenRouter API key (access to multiple models)
OPENROUTER_API_KEY=

# OpenRouter model to use (see https://openrouter.ai/models)
OPENROUTER_MODEL=anthropic/claude-3-opus

# Perplexity API key (search-augmented AI)
PERPLEXITY_API_KEY=

# Perplexity model to use (pplx-7b-online, pplx-70b-online, etc.)
PERPLEXITY_MODEL=pplx-70b-online

# Custom AI provider (if you're using a custom API)
CUSTOM_AI_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# Default AI provider to use (openai, anthropic, google, groq, ollama, openrouter, perplexity, custom)
DEFAULT_AI_PROVIDER=openai

# AI temperature (0.0 - 2.0, higher = more creative)
AI_TEMPERATURE=0.7

# AI max tokens (maximum response length)
AI_MAX_TOKENS=1000

# AI system prompt (personality/instructions for the AI)
AI_SYSTEM_PROMPT=You are a helpful AI assistant integrated into a Discord selfbot.

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------
# Maximum requests per window
RATE_LIMIT_MAX=100

# Rate limit window in milliseconds (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Discord Bot Feature Toggles
# -----------------------------------------------------------------------------
# Enable Rich Presence (RPC) system
ENABLE_RPC=true

# Enable AI auto-responder
ENABLE_AI_RESPONDER=false

# Enable Nitro sniper
ENABLE_NITRO_SNIPER=false

# Enable giveaway joiner
ENABLE_GIVEAWAY_JOINER=false

# Enable message logger (logs deleted/edited messages)
ENABLE_MESSAGE_LOGGER=true

# Enable auto-reactions
ENABLE_AUTO_REACTIONS=false

# Enable AFK system
ENABLE_AFK_SYSTEM=true

# -----------------------------------------------------------------------------
# RPC Configuration
# -----------------------------------------------------------------------------
# Default RPC platform (pc, xbox, playstation, mobile, switch, custom)
RPC_PLATFORM=pc

# Enable RPC animations (rotate through multiple states)
RPC_ANIMATION_ENABLED=false

# RPC animation interval in seconds
RPC_ANIMATION_INTERVAL=30

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
# Enable automatic backups
AUTO_BACKUP_ENABLED=true

# Backup interval in hours
AUTO_BACKUP_INTERVAL_HOURS=24

# Maximum number of backups to keep
AUTO_BACKUP_MAX_BACKUPS=7

# Backup directory
BACKUP_DIR=./backups

# -----------------------------------------------------------------------------
# Caddy Configuration (for production deployment)
# -----------------------------------------------------------------------------
# Your domain name (for HTTPS)
DOMAIN=yourdomain.com

# Email for Let's Encrypt (for HTTPS certificates)
ACME_EMAIL=your@email.com

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Enable CORS (only in development, should be false in production)
ENABLE_CORS=false

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# Maximum login attempts before account lock
MAX_LOGIN_ATTEMPTS=5

# Account lock duration in minutes
ACCOUNT_LOCK_DURATION_MINUTES=30

# Session timeout in hours
SESSION_TIMEOUT_HOURS=24

# -----------------------------------------------------------------------------
# Analytics Configuration
# -----------------------------------------------------------------------------
# Enable analytics tracking
ENABLE_ANALYTICS=true

# Analytics retention in days (how long to keep analytics data)
ANALYTICS_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Advanced Configuration (usually don't need to change)
# -----------------------------------------------------------------------------
# WebSocket ping interval in seconds
WS_PING_INTERVAL=30

# WebSocket connection timeout in seconds
WS_CONNECTION_TIMEOUT=60

# Discord API base URL (usually don't change)
DISCORD_API_BASE=https://discord.com/api/v10

# Discord CDN base URL (usually don't change)
DISCORD_CDN_BASE=https://cdn.discordapp.com

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=10

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# -----------------------------------------------------------------------------
# Docker-Specific Configuration
# -----------------------------------------------------------------------------
# These are only used when running with Docker Compose

# Postgres configuration (if you want to use Postgres instead of SQLite)
# POSTGRES_USER=sabbylink
# POSTGRES_PASSWORD=your_secure_password
# POSTGRES_DB=sabbylink
# DATABASE_URL=postgresql://sabbylink:your_secure_password@postgres:5432/sabbylink

# Redis configuration (if you want to add caching)
# REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Development Configuration
# -----------------------------------------------------------------------------
# Hot reload for backend (true/false)
DEV_HOT_RELOAD=true

# Frontend HMR (Hot Module Replacement) port
DEV_HMR_PORT=24678

# Enable source maps in production (increases bundle size but helps debugging)
ENABLE_SOURCE_MAPS=false

# =============================================================================
# End of Configuration
# =============================================================================

# Quick Start Guide:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your DISCORD_TOKEN (required)
# 3. Generate random secrets for ENCRYPTION_KEY and JWT_SECRET
# 4. Add AI provider API keys if you want AI features
# 5. Set DOMAIN and ACME_EMAIL for production deployment
# 6. Run: docker-compose up -d (production) or bun run dev (development)
